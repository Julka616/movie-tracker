# Skopiuj ten plik jako .env i uzupełnij własnymi wartościami.
# NIGDY nie commituj prawdziwego pliku .env do gita!

# Connection string z MongoDB Atlas (Database -> Connect -> Drivers)
MONGO_URI=mongodb+srv://uzytkownik:haslo@cluster0.xxxxx.mongodb.net/my_movie_app

# Dowolny długi, losowy ciąg znaków (np. wygenerowany przez openssl rand -hex 32)
JWT_SECRET=wpisz_tutaj_dlugi_losowy_ciag_znakow

# Adres Twojego frontendu na produkcji (Vercel/Netlify), po przecinku jeśli więcej niż jeden
FRONTEND_URL=https://twoja-appka.vercel.app

# Render ustawia PORT automatycznie - nie musisz go dodawać ręcznie
TMDB_API_KEY=wpisz_tutaj_swoj_klucz_tmdb
